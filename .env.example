# Vercel AI SDK — Anthropic provider
# Get a key from the internal secrets manager. Never commit the real value.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# Optional: override the default model
ANTHROPIC_MODEL=claude-opus-4-8

# Google OAuth consent flow (obtain refresh token via /auth/google)
GOOGLE_CALLBACK_URL=http://localhost:51515/auth/google/callback
# GOOGLE_REFRESH_TOKEN now optional — seeds the Redis token store on cold start if set
